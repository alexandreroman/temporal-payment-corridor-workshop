# API gateway for the app — the single HTTP entry point.
#
# `/` routes to our payment-corridor Web UI (the app front door); `/temporal`
# routes to the Temporal Web UI; `/api/payments/v1/*` routes to the payments
# API; `/codec/*` routes to the codec server with the shared bearer token
# injected on every forwarded request.
#
# Because the Web UI page, the payments API, and the codec endpoint are all
# served from this one origin (http://localhost:8233), a browser call from
# the UI to `/api/payments/v1` or `/codec` is same-origin: there is NO
# cross-origin request, so the browser sends no CORS preflight and neither
# service needs CORS configuration for the UI.
#
# NOTE: the Temporal Web UI cannot attach a static shared secret itself. The
# UI only forwards a signed-in user's access token, and on a local
# `temporal server start-dev` there is no signed-in user, so no token is sent.
# The gateway therefore injects the secret for it. This is a local-development
# convenience only: in production the UI forwards the user's real access token,
# so no gateway or shared secret is needed.
#
# `temporal`, `codec`, and `payments-api` are Compose services reachable on
# the internal network; none of them publishes a host port.
#
# reverse_proxy directive reference:
# https://caddyserver.com/docs/caddyfile/directives/reverse_proxy

:8233 {
	# handle_path strips the `/codec` prefix before proxying, so a browser
	# request to `/codec/decode` reaches the codec server as `/decode`.
	handle_path /codec/* {
		reverse_proxy codec:8081 {
			# The `:default` fallback matches the codec server's own built-in
			# default token, so the Web UI decodes out of the box even with no
			# `.env`. Set CODEC_SERVER_AUTH_TOKEN to a real secret for real use.
			header_up Authorization "Bearer {$CODEC_SERVER_AUTH_TOKEN:changeme}"
		}
	}
	handle /api/payments/v1/* {
		reverse_proxy {$PAYMENTS_API_UPSTREAM:payments-api:8020}
	}
	# The Temporal Web UI is served under /temporal; the temporal service
	# runs with --ui-public-path /temporal so its assets/links resolve here.
	# NOTE: unlike /codec above, this is a plain `handle` (no handle_path): the
	# UI itself serves its assets under the /temporal prefix, so Caddy must
	# forward the prefix along instead of stripping it.
	handle /temporal* {
		reverse_proxy temporal:8233
	}
	# Everything else is our payment-corridor Web UI (the app front door).
	# NOTE: in dev mode (`make dev`) webui runs on the HOST for hot reload,
	# not as a container, so the containerised gateway can't resolve the
	# Compose service name `webui`. compose.dev.yaml overrides WEBUI_UPSTREAM
	# to dial back out to the host instead, the same way it already does for
	# PAYMENTS_API_UPSTREAM above.
	reverse_proxy {$WEBUI_UPSTREAM:webui:8000}
}
