# Copy to .env and adjust. Loaded automatically by worker.py and simulator.py.

# --- Temporal ---------------------------------------------------------------
# Address of the Temporal frontend (dev server default shown).
TEMPORAL_ADDRESS=localhost:7233

# --- Metrics ----------------------------------------------------------------
# Bind address for the single Prometheus/OpenMetrics endpoint. Scrape it at
# http://<host>:<port>/metrics — serves both temporal_* and corridor_* series.
METRICS_BIND_ADDRESS=0.0.0.0:9464

# --- Agents / LLM -----------------------------------------------------------
# Any Pydantic AI model string. The seeded happy path never calls a model, so
# a key is only required once an anomaly misses corridor memory.
CORRIDOR_MODEL=anthropic:claude-sonnet-4-5
# Provider key matching CORRIDOR_MODEL (uncomment and set to run the agents):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# --- Observability ----------------------------------------------------------
# Optional. When unset, Logfire runs locally and ships nothing.
# LOGFIRE_TOKEN=

# --- Web UI -----------------------------------------------------------------
# Host and port for the FastAPI landing page (dev server). Reach it at
# http://localhost:<WEBUI_PORT>.
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
