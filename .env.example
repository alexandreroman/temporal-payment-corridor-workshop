# Copy to .env and adjust. Loaded automatically by the worker, web UI,
# simulator, and corridor-memory service.

# --- Temporal ---------------------------------------------------------------
# Address of the Temporal frontend (dev server default shown).
TEMPORAL_ADDRESS=localhost:7233
# Namespace for the payment-correction worker: its own bounded context,
# distinct from the memory service's namespace (MEMORY_TEMPORAL_NAMESPACE).
PAYMENTS_TEMPORAL_NAMESPACE=payments
# The dev server pre-creates both the `payments` and `memory` namespaces
# (see the temporal service command in compose.yaml).

# --- Metrics ----------------------------------------------------------------
# Host and port for the single Prometheus/OpenMetrics endpoint. Scrape it at
# http://<host>:<port>/metrics — serves both temporal_* and corridor_* series.
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9464

# --- Agents / LLM -----------------------------------------------------------
# Any Pydantic AI model string. The seeded happy path never calls a model, so
# a key is only required once an anomaly misses corridor memory.
CORRIDOR_MODEL=anthropic:claude-sonnet-5
# Provider key matching CORRIDOR_MODEL (uncomment and set to run the agents):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# --- Web UI -----------------------------------------------------------------
# Host and port for the FastAPI landing page (dev server). Reach it at
# http://localhost:<WEBUI_PORT>.
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000

# --- Corridor memory service ------------------------------------------------
# Host and port for the FastAPI corridor-memory service. Reach it at
# http://localhost:<MEMORY_PORT>; it serves /api/memory/v1 (lookup + remember).
MEMORY_HOST=0.0.0.0
MEMORY_PORT=8010
# The following matters only when the `memory-workflow` FEATURE is enabled: it
# swaps the naive in-memory store for a durable Temporal workflow, so the
# service connects to Temporal (TEMPORAL_ADDRESS above) on its own namespace
# and runs an embedded worker there.
MEMORY_TEMPORAL_NAMESPACE=memory

# --- Encryption (Session 3) --------------------------------------------------
# Fernet key for encrypting payloads at the Temporal boundary. The value below
# is a working but INSECURE dev-only default: it is also baked into the codec
# server as a fallback, so `cp .env.example .env` gives an out-of-the-box setup
# where the worker encrypts with exactly the key the codec expects. Regenerate
# it for anything real:
#   python -c "from cryptography.fernet import Fernet; \
#     print(Fernet.generate_key().decode())"
CODEC_ENCRYPTION_KEY=M80yQxCwjIWwuApHeRjQQoRARc0PhUh6FAEfukmEhlk=

# --- Codec server (Session 3) -----------------------------------------------
# The codec server runs as a Compose service reached only through the gateway —
# it publishes no host port. CODEC_SERVER_HOST/PORT set its in-container bind
# address; CODEC_ENCRYPTION_KEY (above) and CODEC_SERVER_AUTH_TOKEN (below)
# configure decryption and auth. When either is unset the server starts anyway
# with its insecure built-in default and logs a warning.
CODEC_SERVER_HOST=0.0.0.0
CODEC_SERVER_PORT=8081
# Web UI origin allowed to call the codec server (CORS). Not exercised in the
# gateway topology: the Web UI and codec share one origin via the gateway, so
# calls are same-origin and no CORS preflight is sent. This only matters if the
# codec server is exposed directly to the browser.
TEMPORAL_UI_ORIGIN=http://localhost:8233
# Shared bearer token gating the codec server: it rejects any request lacking
# "Authorization: Bearer <this value>". The value below is a working but
# INSECURE dev-only default, also baked into the codec server AND into the
# gateway (which injects it), so the gateway authenticates out of the box.
# Regenerate it for anything real:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CODEC_SERVER_AUTH_TOKEN=changeme
