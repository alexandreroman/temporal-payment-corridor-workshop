# Copy to .env and adjust. Loaded automatically by payments, the
# simulator, and corridor-memory service.
#
# This file works as-is after `cp .env.example .env`: every value ships
# with a working (dev-only, insecure) default. The only value you must set
# to exercise the full agent flow is a provider API key matching
# CORRIDOR_MODEL (see the Agents / LLM section below).

# --- Temporal (shared) ------------------------------------------------------
# Address of the Temporal frontend (dev server default shown).
TEMPORAL_ADDRESS=localhost:7233
# The dev server pre-creates both the `payments` and `memory` namespaces
# (see the temporal service command in compose.yaml).

# --- Payments ---------------------------------------------------------------
# Namespace for payments, the payment-correction service: its own bounded
# context, distinct from the memory service's namespace
# (MEMORY_TEMPORAL_NAMESPACE).
PAYMENTS_TEMPORAL_NAMESPACE=payments
# Host and port for the single Prometheus/OpenMetrics endpoint, bound by the
# payments worker. Scrape it at http://<host>:<port>/metrics — serves both
# temporal_* and corridor_* series. The gateway never routes metrics, and
# container mode publishes no host port for it.
PAYMENTS_METRICS_HOST=0.0.0.0
PAYMENTS_METRICS_PORT=9464
# Host and port for the payments HTTP API (/api/payments/v1) — the payments API
# process binds here. External clients and the simulator reach it through the
# gateway (GATEWAY_HOST/PORT below), never this bind address directly.
PAYMENTS_API_HOST=0.0.0.0
PAYMENTS_API_PORT=8020

# --- Gateway ----------------------------------------------------------------
# The single HTTP entry point in front of the payments API. The simulator posts
# anomalies to http://<GATEWAY_HOST>:<GATEWAY_PORT>/api/payments/v1 rather than
# talking to Temporal or the API bind address directly.
GATEWAY_HOST=localhost
GATEWAY_PORT=8080

# --- Agents / LLM -----------------------------------------------------------
# Any Pydantic AI model string. The seeded happy path never calls a model, so
# a key is only required once an anomaly misses corridor memory.
CORRIDOR_MODEL=anthropic:claude-sonnet-5
# Per-provider examples — set the line above to one of these and uncomment the
# matching key below:
#   CORRIDOR_MODEL=anthropic:claude-sonnet-5 -> ANTHROPIC_API_KEY
#   CORRIDOR_MODEL=openai:gpt-5-mini         -> OPENAI_API_KEY
# Other Pydantic AI providers also work; some (e.g. Groq, Mistral) first
# need their extra added to pyproject.toml (e.g. pydantic-ai-slim[groq])
# and `uv sync`.
# REQUIRED to run the agents — uncomment and set exactly ONE provider key
# matching CORRIDOR_MODEL:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# To run the agents on Azure OpenAI, set the line above to:
#   CORRIDOR_MODEL=azure:<your-deployment-name>
# (the suffix is the Azure deployment name, not a model id) and uncomment
# the endpoint and key below. OPENAI_API_VERSION is optional; it defaults to
# 2024-10-21 when unset.
# Concrete example — a deployment you named "corridor-agents-prod" that
# points at gpt-5-mini, in an Azure resource named "acme-openai":
#   CORRIDOR_MODEL=azure:corridor-agents-prod
#   AZURE_OPENAI_ENDPOINT=https://acme-openai.openai.azure.com
#   AZURE_OPENAI_API_KEY=1a2b3c...
# (azure:corridor-agents-prod says nothing about the underlying model — only
#  the Azure portal knows the deployment maps to gpt-5-mini.)
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# OPENAI_API_VERSION=2024-10-21
#
# To run the agents against a custom OpenAI-compatible endpoint (a proxy,
# LiteLLM, vLLM, or a local server), keep CORRIDOR_MODEL=openai:<model> and
# additionally set OPENAI_BASE_URL plus OPENAI_API_KEY below.
# Concrete example — a local LiteLLM proxy exposing gpt-5-mini:
#   CORRIDOR_MODEL=openai:gpt-5-mini
#   OPENAI_BASE_URL=http://localhost:4000/v1
#   OPENAI_API_KEY=sk-local-...
# OPENAI_BASE_URL=https://.../v1

# --- Corridor memory service ------------------------------------------------
# The corridor-memory service is reached only in-network (as memory:8010),
# never through the gateway or a published host port. MEMORY_HOST/PORT set
# its bind address; in dev mode it runs as a host process bound to these.
MEMORY_HOST=0.0.0.0
MEMORY_PORT=8010
# The following matters only when the `memory-workflow` FEATURE is enabled: it
# swaps the naive in-memory store for a durable Temporal workflow, so the
# service connects to Temporal (TEMPORAL_ADDRESS above) on its own namespace
# and runs an embedded worker there.
MEMORY_TEMPORAL_NAMESPACE=memory

# --- Encryption -------------------------------------------------------------
# Fernet key for encrypting payloads at the Temporal boundary. The value below
# is a working but INSECURE dev-only default: it is also baked into the codec
# server as a fallback, so `cp .env.example .env` gives an out-of-the-box setup
# where payments encrypts with exactly the key the codec expects. Regenerate
# it for anything real:
#   python -c "from cryptography.fernet import Fernet; \
#     print(Fernet.generate_key().decode())"
CODEC_ENCRYPTION_KEY=M80yQxCwjIWwuApHeRjQQoRARc0PhUh6FAEfukmEhlk=

# --- Codec server -----------------------------------------------------------
# The codec server runs as a Compose service reached only through the gateway —
# it publishes no host port. CODEC_SERVER_HOST/PORT set its in-container bind
# address; CODEC_ENCRYPTION_KEY (above) and CODEC_SERVER_AUTH_TOKEN (below)
# configure decryption and auth. When either is unset the server starts anyway
# with its insecure built-in default and logs a warning.
CODEC_SERVER_HOST=0.0.0.0
CODEC_SERVER_PORT=8081
# Shared bearer token gating the codec server: it rejects any request lacking
# "Authorization: Bearer <this value>". The value below is a working but
# INSECURE dev-only default, also baked into the codec server AND into the
# gateway (which injects it), so the gateway authenticates out of the box.
# Regenerate it for anything real:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CODEC_SERVER_AUTH_TOKEN=changeme
